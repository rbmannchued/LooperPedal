@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix pprops: <http://lv2plug.in/ns/ext/port-props#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix urid:  <http://lv2plug.in/ns/ext/urid#> .

<urn:rafa:Looper>
    a lv2:Plugin, lv2:UtilityPlugin ;

    doap:name "Guitar Looper" ;

    lv2:requiredFeature urid:map ;
    lv2:optionalFeature lv2:hardRTCapable ;

    rdfs:label "Guitar Looper" ;
    rdfs:comment """Guitar looper pedal controlled via MIDI.

States (PORT_STATE_OUT):
  0 = Idle, 1 = Recording, 2 = Playing, 3 = Overdubbing, 4 = Paused

MIDI mode (midi_mode port):
  0 = Note On  — triggered by note-on with velocity > 0
  1 = CC       — triggered by CC with value > 0

Default MIDI mapping (note numbers or CC numbers):
  60 — Record / Stop+Play / Overdub toggle
  62 — Clear all
  64 — Pause / Resume
""" ;

    lv2:port [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "in" ;
        lv2:name "Input" ;
    ] , [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 1 ;
        lv2:symbol "out" ;
        lv2:name "Output" ;
    ] , [
        a atom:AtomPort, lv2:InputPort ;
        atom:bufferType atom:Sequence ;
        atom:supports midi:MidiEvent ;
        lv2:index 2 ;
        lv2:symbol "midi_in" ;
        lv2:name "MIDI In" ;
        lv2:designation lv2:control ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 3 ;
        lv2:symbol "rec_note" ;
        lv2:name "Record Note" ;
        lv2:default 60 ;
        lv2:minimum 0 ;
        lv2:maximum 127 ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "MIDI note: record / stop+play / overdub toggle" ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 4 ;
        lv2:symbol "clr_note" ;
        lv2:name "Clear Note" ;
        lv2:default 62 ;
        lv2:minimum 0 ;
        lv2:maximum 127 ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "MIDI note: erase loop and return to idle" ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 5 ;
        lv2:symbol "pause_note" ;
        lv2:name "Pause Note" ;
        lv2:default 64 ;
        lv2:minimum 0 ;
        lv2:maximum 127 ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "MIDI note: pause / resume playback" ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 6 ;
        lv2:symbol "level" ;
        lv2:name "Loop Level" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 2.0 ;
        rdfs:comment "Playback volume of the loop" ;
    ] , [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 7 ;
        lv2:symbol "state_out" ;
        lv2:name "State" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 4 ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "Current state: 0=Idle 1=Recording 2=Playing 3=Overdubbing 4=Paused" ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 8 ;
        lv2:symbol "midi_mode" ;
        lv2:name "MIDI Mode" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:integer, pprops:enumeration ;
        lv2:scalePoint [ rdfs:label "Note On" ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "CC"      ; rdf:value 1 ] ;
        rdfs:comment "MIDI message type: 0=Note On, 1=CC" ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 9 ;
        lv2:symbol "rec_level" ;
        lv2:name "Rec Level" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 2.0 ;
        rdfs:comment "Input gain applied while recording and overdubbing" ;
    ] .
